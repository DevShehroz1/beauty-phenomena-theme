{% style %}
:root {
  /* Color scheme */
  {%- assign scheme = settings.default_color_scheme -%}
  --color-bg: {{ settings['color_scheme_' | append: scheme | append: '_bg'] }};
  --color-text: {{ settings['color_scheme_' | append: scheme | append: '_text'] }};
  --color-accent: {{ settings['color_scheme_' | append: scheme | append: '_accent'] }};
  --color-btn-bg: {{ settings['color_scheme_' | append: scheme | append: '_btn_bg'] }};
  --color-btn-text: {{ settings['color_scheme_' | append: scheme | append: '_btn_text'] }};
  --color-secondary-btn-bg: {{ settings['color_scheme_' | append: scheme | append: '_secondary_btn_bg'] }};
  --color-secondary-btn-text: {{ settings['color_scheme_' | append: scheme | append: '_secondary_btn_text'] }};
  --color-opacity: {{ settings.color_opacity | divided_by: 100.0 }};

  /* Header colors */
  --color-header-bg: {{ settings.header_bg_color }};
  --color-header-link: {{ settings.header_link_color }};
  --color-header-transparent-link: {{ settings.header_transparent_link_color }};

  /* Typography - Headings */
  --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families }};
  --font-heading-weight: {{ settings.heading_font.weight }};
  --font-heading-style: {{ settings.heading_font.style }};
  --font-heading-size: {{ settings.heading_size }}px;
  --heading-uppercase: {% if settings.heading_uppercase %}uppercase{% else %}none{% endif %};
  --heading-letter-spacing: {{ settings.heading_letter_spacing | divided_by: 1000.0 }}em;

  /* Typography - Body */
  --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families }};
  --font-body-weight: {{ settings.body_font.weight }};
  --font-body-style: {{ settings.body_font.style }};
  --font-body-size: {{ settings.body_size }}px;

  /* Typography - Navigation */
  --font-nav: var({% if settings.nav_font_source == 'heading' %}--font-heading{% else %}--font-body{% endif %});
  --font-nav-weight: {{ settings.nav_font_weight }};
  --font-nav-size: {{ settings.nav_size }}px;
  --nav-uppercase: {% if settings.nav_uppercase %}uppercase{% else %}none{% endif %};
  --nav-letter-spacing: {{ settings.nav_letter_spacing | divided_by: 1000.0 }}em;

  /* Typography - Accent */
  --font-accent: {{ settings.accent_font.family }}, {{ settings.accent_font.fallback_families }};
  --font-accent-weight: {{ settings.accent_font.weight }};
  --font-accent-style: {{ settings.accent_font.style }};
  --font-accent-size: {{ settings.accent_size }}px;
  --accent-uppercase: {% if settings.accent_uppercase %}uppercase{% else %}none{% endif %};
  --accent-letter-spacing: {{ settings.accent_letter_spacing | divided_by: 1000.0 }}em;

  /* Typography - Labels */
  --font-label-weight: {{ settings.label_font_weight }};
  --font-label-size: {{ settings.label_size }}px;
  --label-uppercase: {% if settings.label_uppercase %}uppercase{% else %}none{% endif %};
  --label-letter-spacing: {{ settings.label_letter_spacing | divided_by: 1000.0 }}em;

  /* Typography - Highlight */
  --font-highlight: {{ settings.highlight_font.family }}, {{ settings.highlight_font.fallback_families }};
  --font-highlight-weight: {{ settings.highlight_font.weight }};
  --font-highlight-style: {{ settings.highlight_font.style }};

  /* Layout */
  --page-width: {{ settings.page_width }}px;
  --border-radius: {{ settings.border_radius }}px;
  --section-padding: {% case settings.section_padding %}{% when 'small' %}40px{% when 'medium' %}60px{% when 'large' %}80px{% endcase %};

  /* Buttons */
  --btn-border-radius: {{ settings.button_border_radius }}px;
  --btn-font-weight: {{ settings.button_font_weight }};
  --btn-uppercase: {% if settings.button_uppercase %}uppercase{% else %}none{% endif %};
  --btn-padding: {% case settings.button_size %}{% when 'small' %}10px 24px{% when 'medium' %}14px 32px{% when 'large' %}18px 40px{% endcase %};

  /* Animation */
  --transition-duration: 0.3s;
  --transition-ease: cubic-bezier(0.25, 0.1, 0.25, 1);
}

@media (prefers-reduced-motion: reduce) {
  :root {
    --transition-duration: 0.01s;
  }
}
{% endstyle %}

{{ settings.heading_font | font_face: font_display: 'swap' }}
{{ settings.body_font | font_face: font_display: 'swap' }}
{{ settings.accent_font | font_face: font_display: 'swap' }}
{{ settings.highlight_font | font_face: font_display: 'swap' }}
