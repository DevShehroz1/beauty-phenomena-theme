<section class="video-section section-padding" data-section-id="{{ section.id }}">
  <div class="{% unless section.settings.full_width %}page-width{% endunless %}">
    {%- if section.settings.heading != blank -%}
      <div class="video-section__header text-center page-width">
        <h2 class="heading h2 animate-on-scroll">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="video-section__wrapper" style="--video-height: {{ section.settings.height }};">
      {%- if section.settings.video_url != blank -%}
        <div class="video-section__embed">
          {%- if section.settings.video_url contains 'youtube' or section.settings.video_url contains 'youtu.be' -%}
            {%- assign youtube_id = section.settings.video_url | split: 'v=' | last | split: '&' | first -%}
            {%- if section.settings.video_url contains 'youtu.be' -%}
              {%- assign youtube_id = section.settings.video_url | split: 'youtu.be/' | last | split: '?' | first -%}
            {%- endif -%}
            <iframe
              src="https://www.youtube.com/embed/{{ youtube_id }}?autoplay={{ section.settings.autoplay | ternary: 1, 0 }}&mute=1&loop=1&playlist={{ youtube_id }}&controls={{ section.settings.show_controls | ternary: 1, 0 }}&playsinline=1"
              allow="autoplay; encrypted-media"
              allowfullscreen
              class="video-section__iframe"
              loading="lazy"
            ></iframe>
          {%- elsif section.settings.video_url contains 'vimeo' -%}
            {%- assign vimeo_id = section.settings.video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
            <iframe
              src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay={{ section.settings.autoplay | ternary: 1, 0 }}&muted=1&loop=1&background={{ section.settings.show_controls | ternary: 0, 1 }}"
              allow="autoplay"
              allowfullscreen
              class="video-section__iframe"
              loading="lazy"
            ></iframe>
          {%- endif -%}
        </div>
      {%- elsif section.settings.cover_image != blank -%}
        <div class="video-section__cover">
          {{ section.settings.cover_image | image_url: width: 1920 | image_tag: loading: 'lazy', sizes: '100vw', widths: '720, 1080, 1440, 1920' }}
        </div>
      {%- else -%}
        <div class="video-section__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "video_url", "label": "Video URL", "info": "YouTube or Vimeo URL" },
    { "type": "image_picker", "id": "cover_image", "label": "Cover image" },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": true },
    { "type": "checkbox", "id": "show_controls", "label": "Show controls", "default": false },
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": true },
    { "type": "select", "id": "height", "label": "Height", "default": "60vh", "options": [
      { "value": "40vh", "label": "Small" },
      { "value": "60vh", "label": "Medium" },
      { "value": "80vh", "label": "Large" },
      { "value": "100vh", "label": "Full screen" }
    ]}
  ],
  "presets": [{ "name": "Video" }]
}
{% endschema %}
