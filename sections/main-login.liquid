<section class="customer-page section-padding">
  <div class="page-width customer-page__narrow">
    <h1 class="heading h2 text-center">{{ 'customer.login.title' | t }}</h1>
    {%- form 'customer_login' -%}
      {%- if form.errors -%}<div class="form-errors">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="field"><label class="field__label" for="customer-email">{{ 'customer.login.email' | t }}</label><input type="email" id="customer-email" name="customer[email]" class="field__input" autocomplete="email" required></div>
      <div class="field"><label class="field__label" for="customer-password">{{ 'customer.login.password' | t }}</label><input type="password" id="customer-password" name="customer[password]" class="field__input" autocomplete="current-password" required></div>
      <button type="submit" class="btn btn--primary btn--full">{{ 'customer.login.sign_in' | t }}</button>
      <div class="customer-page__links text-center">
        <a href="{{ routes.account_recover_url }}">{{ 'customer.login.forgot_password' | t }}</a>
        <span> &middot; </span>
        <a href="{{ routes.account_register_url }}">{{ 'customer.login.create_account' | t }}</a>
      </div>
    {%- endform -%}
  </div>
</section>
{% schema %} { "name": "Login page" } {% endschema %}
