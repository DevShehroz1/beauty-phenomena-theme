<section class="shop-the-look-grid section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="heading h2 text-center animate-on-scroll">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="shop-the-look-grid__grid grid grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        <div class="shop-the-look-grid__item animate-on-scroll stagger-{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="media media--portrait">{{ block.settings.image | image_url: width: 720 | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 33vw, 100vw', widths: '360, 540, 720' }}</div>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}<h3 class="heading h4">{{ block.settings.heading }}</h3>{%- endif -%}
          {%- assign product = all_products[block.settings.product] -%}
          {%- if product != blank -%}
            <div class="shop-the-look-grid__product">{% render 'product-card', product: product %}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop the look - Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the look" },
    { "type": "select", "id": "columns", "label": "Columns", "default": "3", "options": [
      { "value": "2", "label": "2" }, { "value": "3", "label": "3" }
    ]}
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [{ "name": "Shop the look - Grid", "blocks": [{ "type": "look" }, { "type": "look" }, { "type": "look" }] }]
}
{% endschema %}
