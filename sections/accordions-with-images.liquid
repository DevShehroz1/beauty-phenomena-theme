<section class="accordions-images section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2 class="heading h2 animate-on-scroll">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="accordions-images__grid">
      <div class="accordions-images__media">
        {%- for block in section.blocks -%}
          <div class="accordions-images__image{% if forloop.first %} is-active{% endif %}" data-accordion-image="{{ block.id }}">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 720 | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 50vw, 100vw', widths: '360, 540, 720' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <div class="accordions-images__content">
        {%- for block in section.blocks -%}
          <details class="accordion{% if forloop.first %} is-open{% endif %}"{% if forloop.first %} open{% endif %} data-accordion-trigger="{{ block.id }}" {{ block.shopify_attributes }}>
            <summary class="accordion__trigger"><span class="heading h4">{{ block.settings.heading | default: 'Accordion heading' }}</span>{% render 'icon-plus' %}</summary>
            <div class="accordion__content rte">{{ block.settings.text }}</div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;
  section.querySelectorAll('[data-accordion-trigger]').forEach(details => {
    details.addEventListener('toggle', () => {
      if (details.open) {
        const id = details.dataset.accordionTrigger;
        section.querySelectorAll('.accordions-images__image').forEach(img => img.classList.remove('is-active'));
        section.querySelector(`[data-accordion-image="${id}"]`)?.classList.add('is-active');
        section.querySelectorAll('details[data-accordion-trigger]').forEach(d => { if (d !== details) d.removeAttribute('open'); });
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Accordions with images",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    { "type": "item", "name": "Accordion item", "settings": [
      { "type": "text", "id": "heading", "label": "Heading", "default": "Accordion heading" },
      { "type": "richtext", "id": "text", "label": "Content" },
      { "type": "image_picker", "id": "image", "label": "Image" }
    ]}
  ],
  "presets": [{ "name": "Accordions with images", "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }] }]
}
{% endschema %}
