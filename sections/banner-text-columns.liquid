<section class="banner-text-columns section-padding" data-section-id="{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <div class="banner-text-columns__banner">
      {{ section.settings.image | image_url: width: 1920 | image_tag: loading: 'lazy', sizes: '100vw', widths: '720, 1080, 1440, 1920', class: 'banner-text-columns__image' }}
      {%- if section.settings.heading != blank -%}
        <div class="banner-text-columns__overlay page-width">
          <h2 class="heading h1 animate-on-scroll">{{ section.settings.heading }}</h2>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="page-width">
    <div class="banner-text-columns__grid grid grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        <div class="banner-text-columns__column animate-on-scroll stagger-{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="banner-text-columns__icon">{{ block.settings.icon }}</div>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h3 class="heading h4">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p>{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Banner with text columns",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Banner image" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "select", "id": "columns", "label": "Columns", "default": "3", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" }
    ]}
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji or text)" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "text", "label": "Text" }
      ]
    }
  ],
  "presets": [{ "name": "Banner with text columns", "blocks": [{ "type": "column" }, { "type": "column" }, { "type": "column" }] }]
}
{% endschema %}
