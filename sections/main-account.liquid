<section class="customer-page section-padding">
  <div class="page-width">
    <div class="customer-page__header">
      <h1 class="heading h2">{{ 'customer.account.title' | t }}</h1>
      <a href="{{ routes.account_logout_url }}">{{ 'customer.account.log_out' | t }}</a>
    </div>

    <div class="customer-page__grid">
      <div>
        <h2 class="heading h3">{{ 'customer.account.order_history' | t }}</h2>
        {%- if customer.orders.size > 0 -%}
          <table class="customer-page__table">
            <thead>
              <tr>
                <th>{{ 'customer.orders.order_number' | t }}</th>
                <th>{{ 'customer.orders.date' | t }}</th>
                <th>{{ 'customer.orders.payment_status' | t }}</th>
                <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
                <th>{{ 'customer.orders.total' | t }}</th>
              </tr>
            </thead>
            <tbody>
              {%- for order in customer.orders -%}
                <tr>
                  <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                  <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
                  <td>{{ order.financial_status_label }}</td>
                  <td>{{ order.fulfillment_status_label }}</td>
                  <td>{{ order.total_price | money }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        {%- else -%}
          <p>No orders yet.</p>
        {%- endif -%}
      </div>

      <div>
        <h2 class="heading h3">{{ 'customer.account.details' | t }}</h2>
        <p>{{ customer.name }}</p>
        <p>{{ customer.email }}</p>
        {%- if customer.default_address -%}
          <p>{{ customer.default_address | format_address }}</p>
        {%- endif -%}
        <a href="{{ routes.account_addresses_url }}" class="accent-text">{{ 'customer.account.addresses' | t }}</a>
      </div>
    </div>
  </div>
</section>
{% schema %} { "name": "Account page" } {% endschema %}
