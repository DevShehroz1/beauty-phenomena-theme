{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="main-product section-padding" data-section-id="{{ section.id }}" data-product-json='{{ product | json }}'>
  <div class="page-width">
    {% render 'breadcrumb' %}

    <div class="main-product__grid">
      {%- comment -%} Image Gallery {%- endcomment -%}
      <div class="main-product__media">
        <div class="main-product__gallery" data-product-gallery>
          {%- for media in product.media -%}
            <div class="main-product__media-item{% if forloop.first %} is-active{% endif %}" data-media-id="{{ media.id }}">
              {%- if media.media_type == 'image' -%}
                <div class="main-product__image-wrapper" data-image-zoom>
                  {{ media | image_url: width: 1200 | image_tag: loading: forloop.first | ternary: 'eager', 'lazy', sizes: '(min-width: 768px) 50vw, 100vw', widths: '360, 540, 720, 960, 1200', class: 'main-product__image' }}
                </div>
              {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
                <div class="main-product__video">
                  {{ media | media_tag: class: 'main-product__video-player' }}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="main-product__thumbnails" data-product-thumbnails>
            {%- for media in product.media -%}
              <button class="main-product__thumb{% if forloop.first %} is-active{% endif %}" data-thumb-index="{{ forloop.index0 }}" data-media-id="{{ media.id }}">
                {{ media | image_url: width: 120 | image_tag: loading: 'lazy', width: 80, height: 80, class: 'main-product__thumb-img' }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Product Info {%- endcomment -%}
      <div class="main-product__info">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when '@app' -%}
              {% render block %}

            {%- when 'title' -%}
              <div class="main-product__title-block" {{ block.shopify_attributes }}>
                {%- if product.vendor != blank and block.settings.show_vendor -%}
                  <p class="main-product__vendor accent-text">{{ product.vendor }}</p>
                {%- endif -%}
                <h1 class="main-product__title heading h2">{{ product.title }}</h1>
                {% render 'price', product: product, variant: current_variant %}
              </div>

            {%- when 'variant_selector' -%}
              <div class="main-product__variants" {{ block.shopify_attributes }}>
                {%- for option in product.options_with_values -%}
                  {%- assign option_name_lower = option.name | downcase -%}
                  {%- if option_name_lower == 'color' or option_name_lower == 'colour' -%}
                    <div class="main-product__option">
                      <label class="field__label">{{ option.name }}: <span data-option-value>{{ option.selected_value }}</span></label>
                      {% render 'swatch', product: product, style: block.settings.swatch_style %}
                    </div>
                  {%- else -%}
                    <div class="main-product__option field">
                      <label class="field__label" for="option-{{ option.name | handleize }}">{{ option.name }}</label>
                      <select id="option-{{ option.name | handleize }}" class="field__input" data-option-selector>
                        {%- for value in option.values -%}
                          <option value="{{ value }}" {% if value == option.selected_value %}selected{% endif %}>{{ value }}</option>
                        {%- endfor -%}
                      </select>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
                <select name="id" class="hidden" data-variant-select>
                  {%- for variant in product.variants -%}
                    <option value="{{ variant.id }}" {% if variant == current_variant %}selected{% endif %} data-available="{{ variant.available }}">{{ variant.title }} - {{ variant.price | money }}</option>
                  {%- endfor -%}
                </select>
              </div>

            {%- when 'quantity_selector' -%}
              <div class="main-product__quantity" {{ block.shopify_attributes }}>
                {% render 'quantity-selector', value: 1 %}
              </div>

            {%- when 'buy_buttons' -%}
              <div class="main-product__buy-buttons" {{ block.shopify_attributes }}>
                <form method="post" action="{{ routes.cart_add_url }}" data-product-form>
                  <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
                  <input type="hidden" name="quantity" value="1" data-quantity-value>
                  <button type="submit" class="btn btn--primary btn--full main-product__add-to-cart" data-add-to-cart {% unless current_variant.available %}disabled{% endunless %}>
                    {%- if current_variant.available -%}
                      {%- if product.tags contains 'pre-order' -%}{{ 'products.product.pre_order' | t }}{%- else -%}{{ 'products.product.add_to_cart' | t }}{%- endif -%}
                    {%- else -%}
                      {{ 'products.product.sold_out' | t }}
                    {%- endif -%}
                  </button>
                  {%- if settings.enable_dynamic_checkout and block.settings.show_dynamic_checkout -%}
                    {{ form | payment_button }}
                  {%- endif -%}
                </form>
              </div>

            {%- when 'description' -%}
              <div class="main-product__description rte" {{ block.shopify_attributes }}>
                {{ product.description }}
              </div>

            {%- when 'accordion' -%}
              <details class="accordion main-product__accordion" {{ block.shopify_attributes }}>
                <summary class="accordion__trigger"><span class="heading h4">{{ block.settings.heading | default: 'Details' }}</span>{% render 'icon-plus' %}</summary>
                <div class="accordion__content rte">
                  {%- if block.settings.page != blank -%}
                    {{ block.settings.page.content }}
                  {%- else -%}
                    {{ block.settings.text }}
                  {%- endif -%}
                </div>
              </details>

            {%- when 'badges' -%}
              <div class="main-product__badges" {{ block.shopify_attributes }}>
                {% render 'badge', product: product %}
              </div>

            {%- when 'sharing' -%}
              <div class="main-product__sharing" {{ block.shopify_attributes }}>
                {% render 'social-sharing' %}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} Sticky Add to Cart {%- endcomment -%}
  <div class="sticky-atc" data-sticky-atc aria-hidden="true">
    <div class="page-width sticky-atc__inner">
      <div class="sticky-atc__info">
        {%- if product.featured_media -%}
          {{ product.featured_media | image_url: width: 80 | image_tag: width: 48, height: 48, class: 'sticky-atc__image' }}
        {%- endif -%}
        <div>
          <span class="sticky-atc__title">{{ product.title }}</span>
          <span class="sticky-atc__price" data-sticky-price>{{ current_variant.price | money }}</span>
        </div>
      </div>
      <button class="btn btn--primary sticky-atc__btn" data-sticky-atc-btn {% unless current_variant.available %}disabled{% endunless %}>
        {{ 'products.product.add_to_cart' | t }}
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product page",
  "tag": "div",
  "blocks": [
    { "type": "@app" },
    { "type": "title", "name": "Title & price", "limit": 1, "settings": [
      { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": true }
    ]},
    { "type": "variant_selector", "name": "Variant selector", "limit": 1, "settings": [
      { "type": "select", "id": "swatch_style", "label": "Swatch style", "default": "circle", "options": [
        { "value": "circle", "label": "Circle" }, { "value": "rectangle", "label": "Rectangle" }
      ]}
    ]},
    { "type": "quantity_selector", "name": "Quantity selector", "limit": 1 },
    { "type": "buy_buttons", "name": "Buy buttons", "limit": 1, "settings": [
      { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout", "default": true }
    ]},
    { "type": "description", "name": "Description", "limit": 1 },
    { "type": "accordion", "name": "Accordion", "settings": [
      { "type": "text", "id": "heading", "label": "Heading", "default": "Details" },
      { "type": "richtext", "id": "text", "label": "Content" },
      { "type": "page", "id": "page", "label": "Page content (overrides text)" }
    ]},
    { "type": "badges", "name": "Badges", "limit": 1 },
    { "type": "sharing", "name": "Social sharing", "limit": 1 }
  ],
  "default": {
    "blocks": [
      { "type": "title" },
      { "type": "variant_selector" },
      { "type": "quantity_selector" },
      { "type": "buy_buttons" },
      { "type": "description" },
      { "type": "accordion", "settings": { "heading": "Shipping & Returns" } },
      { "type": "sharing" }
    ]
  }
}
{% endschema %}
