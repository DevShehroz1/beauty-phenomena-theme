<section class="social-gallery section-padding" data-section-id="{{ section.id }}">
  <div class="{% unless section.settings.full_width %}page-width{% endunless %}">
    {%- if section.settings.heading != blank -%}<h2 class="heading h2 text-center page-width animate-on-scroll">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="social-gallery__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: settings.social_instagram | default: '#' }}" target="_blank" rel="noopener" class="social-gallery__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 480 | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 16vw, 33vw', widths: '240, 480' }}
          {%- else -%}
            {{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag }}
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social gallery",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Follow us @beautyphenomena" },
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": true }
  ],
  "blocks": [
    { "type": "image", "name": "Image", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "url", "id": "link", "label": "Link" }
    ]}
  ],
  "presets": [{ "name": "Social gallery", "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }] }]
}
{% endschema %}
