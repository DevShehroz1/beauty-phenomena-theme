<section class="newsletter section-padding" data-section-id="{{ section.id }}" {% if section.settings.image != blank %}style="background-image: url('{{ section.settings.image | image_url: width: 1920 }}');"{% endif %}>
  <div class="page-width text-center">
    <div class="newsletter__content animate-on-scroll">
      {%- if section.settings.subheading != blank -%}<p class="accent-text">{{ section.settings.subheading }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="heading h2">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p class="newsletter__text">{{ section.settings.text }}</p>{%- endif -%}
      {%- form 'customer', id: 'section-newsletter' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter__form">
          <input type="email" name="contact[email]" class="field__input newsletter__input" placeholder="{{ 'newsletter.email_placeholder' | t }}" required autocomplete="email">
          <button type="submit" class="btn btn--primary">{{ 'newsletter.submit' | t }}</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Subscribe to our newsletter" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "image_picker", "id": "image", "label": "Background image" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
