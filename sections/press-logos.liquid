<section class="press-logos section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2 class="heading h2 text-center animate-on-scroll">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="press-logos__grid">
      {%- for block in section.blocks -%}
        <div class="press-logos__item animate-on-scroll stagger-{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" target="_blank" rel="noopener">{%- endif -%}
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', class: 'press-logos__logo' }}
            {%- else -%}
              <span class="press-logos__placeholder">Logo</span>
            {%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Press / Logos",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "As seen in" }
  ],
  "blocks": [
    { "type": "logo", "name": "Logo", "settings": [
      { "type": "image_picker", "id": "image", "label": "Logo image" },
      { "type": "url", "id": "link", "label": "Link" }
    ]}
  ],
  "presets": [{ "name": "Press / Logos", "blocks": [{ "type": "logo" }, { "type": "logo" }, { "type": "logo" }, { "type": "logo" }] }]
}
{% endschema %}
