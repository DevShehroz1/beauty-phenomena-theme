<div
  class="slideshow{% if section.settings.full_width %} slideshow--full{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="slideshow"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ section.settings.speed }}"
  data-transition="{{ section.settings.transition }}"
  data-parallax="{{ section.settings.parallax }}"
  style="--slide-height: {{ section.settings.height }};"
>
  <div class="slideshow__slides" data-slideshow>
    {%- for block in section.blocks -%}
      <div
        class="slideshow__slide{% if forloop.first %} is-active{% endif %}"
        data-slide-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
        {% if block.settings.overlay_opacity > 0 %}
          style="--overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
        {% endif %}
      >
        {%- if block.settings.image != blank -%}
          <div class="slideshow__image-wrapper">
            {{
              block.settings.image
              | image_url: width: 1920
              | image_tag:
                loading: forloop.first | ternary: 'eager', 'lazy',
                sizes: '100vw',
                widths: '720, 1080, 1440, 1920',
                class: 'slideshow__image'
            }}
          </div>
        {%- elsif block.settings.video_url != blank -%}
          <div class="slideshow__video-wrapper">
            {%- if block.settings.video_url contains 'youtube' or block.settings.video_url contains 'youtu.be' -%}
              <iframe src="{{ block.settings.video_url | replace: 'watch?v=', 'embed/' }}?autoplay=1&mute=1&loop=1&controls=0&playsinline=1" allow="autoplay; encrypted-media" allowfullscreen class="slideshow__video"></iframe>
            {%- elsif block.settings.video_url contains 'vimeo' -%}
              <iframe src="{{ block.settings.video_url | replace: 'vimeo.com/', 'player.vimeo.com/video/' }}?autoplay=1&muted=1&loop=1&background=1" allow="autoplay" class="slideshow__video"></iframe>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="slideshow__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}

        <div class="slideshow__overlay"></div>

        <div class="slideshow__content page-width" style="text-align: {{ block.settings.text_alignment }};">
          {%- if block.settings.subheading != blank -%}
            <p class="slideshow__subheading accent-text animate-on-scroll">{{ block.settings.subheading }}</p>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="slideshow__heading heading h1 animate-on-scroll stagger-1">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="slideshow__text animate-on-scroll stagger-2">{{ block.settings.text }}</p>
          {%- endif -%}
          <div class="slideshow__buttons animate-on-scroll stagger-3">
            {%- if block.settings.button_text != blank -%}
              <a href="{{ block.settings.button_link }}" class="btn btn--primary">{{ block.settings.button_text }}</a>
            {%- endif -%}
            {%- if block.settings.button_text_2 != blank -%}
              <a href="{{ block.settings.button_link_2 }}" class="btn btn--secondary">{{ block.settings.button_text_2 }}</a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="slideshow__nav">
      <button class="slideshow__arrow slideshow__arrow--prev" data-slide-prev aria-label="{{ 'accessibility.previous_slide' | t }}">
        {% render 'icon-arrow' %}
      </button>
      <div class="slideshow__dots" data-slide-dots>
        {%- for block in section.blocks -%}
          <button class="slideshow__dot{% if forloop.first %} is-active{% endif %}" data-slide-dot="{{ forloop.index0 }}" aria-label="{{ 'accessibility.slider_pagination' | t: current: forloop.index, total: section.blocks.size }}"></button>
        {%- endfor -%}
      </div>
      <button class="slideshow__arrow slideshow__arrow--next" data-slide-next aria-label="{{ 'accessibility.next_slide' | t }}">
        {% render 'icon-arrow' %}
      </button>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Slideshow",
  "tag": "section",
  "class": "section-slideshow",
  "settings": [
    { "type": "select", "id": "height", "label": "Height", "default": "80vh", "options": [
      { "value": "50vh", "label": "Small" },
      { "value": "65vh", "label": "Medium" },
      { "value": "80vh", "label": "Large" },
      { "value": "100vh", "label": "Full screen" }
    ]},
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Auto-play", "default": true },
    { "type": "range", "id": "speed", "label": "Slide duration", "min": 3, "max": 10, "step": 1, "default": 5, "unit": "s" },
    { "type": "select", "id": "transition", "label": "Transition", "default": "fade", "options": [
      { "value": "fade", "label": "Fade" },
      { "value": "slide", "label": "Slide" }
    ]},
    { "type": "checkbox", "id": "parallax", "label": "Parallax effect", "default": false }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "video_url", "label": "Video URL", "info": "YouTube or Vimeo URL" },
        { "type": "text", "id": "subheading", "label": "Subheading" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Slide heading" },
        { "type": "text", "id": "text", "label": "Text" },
        { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop now" },
        { "type": "url", "id": "button_link", "label": "Button link" },
        { "type": "text", "id": "button_text_2", "label": "Second button text" },
        { "type": "url", "id": "button_link_2", "label": "Second button link" },
        { "type": "select", "id": "text_alignment", "label": "Text alignment", "default": "center", "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ]},
        { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "default": 20, "unit": "%" }
      ]
    }
  ],
  "presets": [{ "name": "Slideshow", "blocks": [{ "type": "slide" }, { "type": "slide" }] }]
}
{% endschema %}
