<section class="split-images" data-section-id="{{ section.id }}">
  <div class="split-images__grid">
    {%- for block in section.blocks -%}
      <div class="split-images__item" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link | default: '#' }}" class="split-images__link">
          <div class="split-images__media media media--{{ section.settings.aspect_ratio | default: 'portrait' }}">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 960 | image_tag: loading: 'lazy', sizes: '50vw', widths: '480, 720, 960', class: 'split-images__image' }}
            {%- else -%}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="split-images__overlay">
            {%- if block.settings.heading != blank -%}
              <h3 class="split-images__heading heading h2 animate-on-scroll">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="split-images__text animate-on-scroll stagger-1">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        </a>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Split images",
  "settings": [
    { "type": "select", "id": "aspect_ratio", "label": "Aspect ratio", "default": "portrait", "options": [
      { "value": "square", "label": "Square" },
      { "value": "portrait", "label": "Portrait" },
      { "value": "landscape", "label": "Landscape" }
    ]}
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 2,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "text", "id": "text", "label": "Text" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Split images", "blocks": [{ "type": "image" }, { "type": "image" }] }]
}
{% endschema %}
