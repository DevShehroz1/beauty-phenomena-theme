<section class="customer-page section-padding">
  <div class="page-width customer-page__narrow">
    <h1 class="heading h2 text-center">{{ 'customer.register.title' | t }}</h1>
    {%- form 'create_customer' -%}
      {%- if form.errors -%}<div class="form-errors">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="customer-page__row">
        <div class="field"><label class="field__label" for="first-name">{{ 'customer.register.first_name' | t }}</label><input type="text" id="first-name" name="customer[first_name]" class="field__input" required></div>
        <div class="field"><label class="field__label" for="last-name">{{ 'customer.register.last_name' | t }}</label><input type="text" id="last-name" name="customer[last_name]" class="field__input" required></div>
      </div>
      <div class="field"><label class="field__label" for="reg-email">{{ 'customer.register.email' | t }}</label><input type="email" id="reg-email" name="customer[email]" class="field__input" autocomplete="email" required></div>
      <div class="field"><label class="field__label" for="reg-password">{{ 'customer.register.password' | t }}</label><input type="password" id="reg-password" name="customer[password]" class="field__input" autocomplete="new-password" required></div>
      <button type="submit" class="btn btn--primary btn--full">{{ 'customer.register.submit' | t }}</button>
    {%- endform -%}
  </div>
</section>
{% schema %} { "name": "Register page" } {% endschema %}
