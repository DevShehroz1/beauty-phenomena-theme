<section class="overlapping-images section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="overlapping-images__grid">
      {%- for block in section.blocks -%}
        <div class="overlapping-images__item overlapping-images__item--{{ forloop.index }} image-reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 720 | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 40vw, 80vw', widths: '360, 540, 720' }}
          {%- else -%}
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.heading != blank -%}
      <div class="overlapping-images__text text-center animate-on-scroll">
        <h2 class="heading h2">{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
        {%- if section.settings.button_text != blank -%}<a href="{{ section.settings.button_link }}" class="btn btn--primary">{{ section.settings.button_text }}</a>{%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Overlapping images",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "button_text", "label": "Button text" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [{ "name": "Overlapping images", "blocks": [{ "type": "image" }, { "type": "image" }] }]
}
{% endschema %}
