<section class="main-password section-padding">
  <div class="page-width text-center customer-page__narrow">
    {%- if settings.logo != blank -%}
      <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="200" class="main-password__logo">
    {%- else -%}
      <h1 class="heading h1">{{ shop.name }}</h1>
    {%- endif -%}

    <p class="main-password__text">{{ 'general.loading' | t | default: 'Opening soon' }}</p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}<div class="form-errors">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="main-password__form">
        <input type="password" name="password" class="field__input" placeholder="Enter password">
        <button type="submit" class="btn btn--primary">Enter</button>
      </div>
    {%- endform -%}

    {%- if shop.password_message != blank -%}
      <div class="main-password__message rte">{{ shop.password_message }}</div>
    {%- endif -%}
  </div>
</section>
{% schema %} { "name": "Password page" } {% endschema %}
