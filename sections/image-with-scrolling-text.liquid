<section class="image-scrolling-text section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="image-scrolling-text__grid">
      <div class="image-scrolling-text__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 720 | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 50vw, 100vw', widths: '360, 540, 720' }}
        {%- else -%}
          <div class="media media--portrait">{{ 'image' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>
      <div class="image-scrolling-text__content">
        {%- for block in section.blocks -%}
          <div class="image-scrolling-text__item animate-on-scroll" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}<h3 class="heading h3">{{ block.settings.heading }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<div class="rte">{{ block.settings.text }}</div>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with scrolling text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "blocks": [
    { "type": "text_block", "name": "Text block", "settings": [
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "richtext", "id": "text", "label": "Text" }
    ]}
  ],
  "presets": [{ "name": "Image with scrolling text", "blocks": [{ "type": "text_block" }, { "type": "text_block" }, { "type": "text_block" }] }]
}
{% endschema %}
