<section class="icons-row section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="icons-row__grid grid grid--{{ section.blocks.size | at_most: 4 }}">
      {%- for block in section.blocks -%}
        <div class="icons-row__item text-center animate-on-scroll stagger-{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}<div class="icons-row__icon">{{ block.settings.icon }}</div>{%- endif -%}
          {%- if block.settings.image != blank -%}<div class="icons-row__icon">{{ block.settings.image | image_url: width: 64 | image_tag: loading: 'lazy', width: 48 }}</div>{%- endif -%}
          {%- if block.settings.heading != blank -%}<h3 class="heading h4">{{ block.settings.heading }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<p class="icons-row__text">{{ block.settings.text }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Icons row",
  "blocks": [
    { "type": "icon", "name": "Icon", "settings": [
      { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "✨" },
      { "type": "image_picker", "id": "image", "label": "Icon image (overrides emoji)" },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Feature" },
      { "type": "text", "id": "text", "label": "Text" }
    ]}
  ],
  "presets": [{ "name": "Icons row", "blocks": [{ "type": "icon" }, { "type": "icon" }, { "type": "icon" }, { "type": "icon" }] }]
}
{% endschema %}
