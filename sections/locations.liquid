<section class="locations section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2 class="heading h2 text-center animate-on-scroll">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="grid grid--{{ section.blocks.size | at_most: 3 }}">
      {%- for block in section.blocks -%}
        <div class="locations__item animate-on-scroll stagger-{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="media media--landscape">{{ block.settings.image | image_url: width: 540 | image_tag: loading: 'lazy' }}</div>
          {%- endif -%}
          {%- if block.settings.name != blank -%}<h3 class="heading h4">{{ block.settings.name }}</h3>{%- endif -%}
          {%- if block.settings.address != blank -%}<p class="locations__address">{{ block.settings.address }}</p>{%- endif -%}
          {%- if block.settings.hours != blank -%}<p class="locations__hours label-text">{{ block.settings.hours }}</p>{%- endif -%}
          {%- if block.settings.phone != blank -%}<p class="locations__phone"><a href="tel:{{ block.settings.phone | remove: ' ' }}">{{ block.settings.phone }}</a></p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Locations",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our stores" }
  ],
  "blocks": [
    { "type": "location", "name": "Location", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "name", "label": "Store name" },
      { "type": "textarea", "id": "address", "label": "Address" },
      { "type": "text", "id": "hours", "label": "Hours" },
      { "type": "text", "id": "phone", "label": "Phone" }
    ]}
  ],
  "presets": [{ "name": "Locations", "blocks": [{ "type": "location" }] }]
}
{% endschema %}
