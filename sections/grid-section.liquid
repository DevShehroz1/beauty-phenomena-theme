<section class="grid-section section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2 class="heading h2 text-center animate-on-scroll">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="grid-section__grid" style="--grid-gap: {{ section.settings.gap }}px;">
      {%- for block in section.blocks -%}
        <div class="grid-section__item animate-on-scroll" style="grid-column: span {{ block.settings.column_span }}; grid-row: span {{ block.settings.row_span }};" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="media" style="height: 100%;">{{ block.settings.image | image_url: width: 720 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}</div>
          {%- endif -%}
          {%- if block.settings.heading != blank or block.settings.text != blank -%}
            <div class="grid-section__content">
              {%- if block.settings.heading != blank -%}<h3 class="heading h4">{{ block.settings.heading }}</h3>{%- endif -%}
              {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "range", "id": "gap", "label": "Gap", "min": 0, "max": 40, "step": 4, "default": 16, "unit": "px" }
  ],
  "blocks": [
    { "type": "item", "name": "Grid item", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "textarea", "id": "text", "label": "Text" },
      { "type": "range", "id": "column_span", "label": "Column span", "min": 1, "max": 3, "step": 1, "default": 1 },
      { "type": "range", "id": "row_span", "label": "Row span", "min": 1, "max": 2, "step": 1, "default": 1 }
    ]}
  ],
  "presets": [{ "name": "Grid", "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }, { "type": "item" }] }]
}
{% endschema %}
