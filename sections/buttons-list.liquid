<section class="buttons-list section-padding" data-section-id="{{ section.id }}">
  <div class="page-width text-center">
    {%- if section.settings.heading != blank -%}<h2 class="heading h2 animate-on-scroll">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="buttons-list__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="btn btn--{{ block.settings.style | default: 'primary' }} animate-on-scroll stagger-{{ forloop.index }}" {{ block.shopify_attributes }}>{{ block.settings.text | default: 'Button' }}</a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Buttons list",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" }
  ],
  "blocks": [
    { "type": "button", "name": "Button", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Shop now" },
      { "type": "url", "id": "link", "label": "Link" },
      { "type": "select", "id": "style", "label": "Style", "default": "primary", "options": [
        { "value": "primary", "label": "Primary" }, { "value": "secondary", "label": "Secondary" }
      ]}
    ]}
  ],
  "presets": [{ "name": "Buttons list", "blocks": [{ "type": "button" }, { "type": "button" }] }]
}
{% endschema %}
