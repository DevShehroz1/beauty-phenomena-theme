{{ 'section-marquee.css' | asset_url | stylesheet_tag }}

<section class="marquee" data-section-id="{{ section.id }}" style="--marquee-speed: {{ section.settings.speed }}s; background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="marquee__track" data-marquee{% if section.settings.pause_on_hover %} data-pause-hover{% endif %}>
    <div class="marquee__content">
      {%- for block in section.blocks -%}
        {%- if block.type == 'text' -%}
          <span class="marquee__item{% if block.settings.highlight %} marquee__item--highlight{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.highlight -%}<em class="highlight-text">{{ block.settings.text }}</em>{%- else -%}{{ block.settings.text }}{%- endif -%}
          </span>
        {%- elsif block.type == 'image' -%}
          <span class="marquee__item marquee__item--image" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: height: 40 | image_tag: loading: 'lazy' }}
            {%- endif -%}
          </span>
        {%- endif -%}
        <span class="marquee__separator">{{ section.settings.separator | default: '—' }}</span>
      {%- endfor -%}
    </div>
    <div class="marquee__content" aria-hidden="true">
      {%- for block in section.blocks -%}
        {%- if block.type == 'text' -%}
          <span class="marquee__item{% if block.settings.highlight %} marquee__item--highlight{% endif %}">
            {%- if block.settings.highlight -%}<em class="highlight-text">{{ block.settings.text }}</em>{%- else -%}{{ block.settings.text }}{%- endif -%}
          </span>
        {%- elsif block.type == 'image' -%}
          <span class="marquee__item marquee__item--image">
            {%- if block.settings.image != blank -%}{{ block.settings.image | image_url: height: 40 | image_tag: loading: 'lazy' }}{%- endif -%}
          </span>
        {%- endif -%}
        <span class="marquee__separator">{{ section.settings.separator | default: '—' }}</span>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "range", "id": "speed", "label": "Speed", "min": 5, "max": 40, "step": 1, "default": 20, "unit": "s" },
    { "type": "text", "id": "separator", "label": "Separator", "default": "—" },
    { "type": "checkbox", "id": "pause_on_hover", "label": "Pause on hover", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#FAF7F4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2C2C2C" }
  ],
  "blocks": [
    { "type": "text", "name": "Text", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Marquee text" },
      { "type": "checkbox", "id": "highlight", "label": "Highlight style", "default": false }
    ]},
    { "type": "image", "name": "Image", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" }
    ]}
  ],
  "presets": [{ "name": "Marquee", "blocks": [{ "type": "text" }, { "type": "text" }, { "type": "text" }] }]
}
{% endschema %}
