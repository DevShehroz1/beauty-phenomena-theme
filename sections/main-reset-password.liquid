<section class="customer-page section-padding">
  <div class="page-width customer-page__narrow">
    <h1 class="heading h2 text-center">{{ 'customer.reset_password.title' | t }}</h1>
    {%- form 'recover_customer_password' -%}
      {%- if form.posted_successfully? -%}<p class="form-success">{{ 'customer.reset_password.success' | t }}</p>{%- endif -%}
      {%- if form.errors -%}<div class="form-errors">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="field"><label class="field__label" for="recover-email">{{ 'customer.reset_password.email' | t }}</label><input type="email" id="recover-email" name="email" class="field__input" autocomplete="email" required></div>
      <button type="submit" class="btn btn--primary btn--full">{{ 'customer.reset_password.submit' | t }}</button>
    {%- endform -%}
  </div>
</section>
{% schema %} { "name": "Reset password page" } {% endschema %}
