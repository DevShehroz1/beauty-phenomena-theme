<section class="text-columns-images section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2 class="heading h2 text-center animate-on-scroll">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="grid grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        <div class="text-columns-images__item animate-on-scroll stagger-{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="text-columns-images__image media media--landscape">
              {{ block.settings.image | image_url: width: 540 | image_tag: loading: 'lazy', sizes: '(min-width: 768px) 33vw, 100vw', widths: '270, 540' }}
            </div>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}<h3 class="heading h4">{{ block.settings.heading }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<div class="rte">{{ block.settings.text }}</div>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Text columns with images",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "select", "id": "columns", "label": "Columns", "default": "2", "options": [
      { "value": "2", "label": "2" }, { "value": "3", "label": "3" }
    ]}
  ],
  "blocks": [
    { "type": "column", "name": "Column", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "heading", "label": "Heading" },
      { "type": "richtext", "id": "text", "label": "Text" }
    ]}
  ],
  "presets": [{ "name": "Text columns with images", "blocks": [{ "type": "column" }, { "type": "column" }] }]
}
{% endschema %}
