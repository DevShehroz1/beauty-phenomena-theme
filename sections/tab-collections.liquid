{{ 'section-tab-collections.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}

<section class="tab-collections section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="tab-collections__header text-center">
        <h2 class="heading h2 animate-on-scroll">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="tab-collections__tabs" role="tablist">
        {%- for block in section.blocks -%}
          {%- assign collection = collections[block.settings.collection] -%}
          <button
            class="tab-collections__tab label-text{% if forloop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="tab-panel-{{ block.id }}"
            data-tab-trigger="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.title | default: collection.title | default: 'Collection' }}
          </button>
        {%- endfor -%}
      </div>

      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <div
          class="tab-collections__panel{% if forloop.first %} is-active{% endif %}"
          id="tab-panel-{{ block.id }}"
          role="tabpanel"
          data-tab-panel="{{ block.id }}"
          {% unless forloop.first %}hidden{% endunless %}
        >
          <div class="grid grid--{{ section.settings.columns }}">
            {%- if collection != blank -%}
              {%- for product in collection.products limit: section.settings.products_to_show -%}
                <div>{% render 'product-card', product: product %}</div>
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..4) -%}
                <div>
                  <div class="product-card"><div class="product-card__media media media--portrait">{{ 'product-' | append: forloop.index | placeholder_svg_tag }}</div><div class="product-card__info"><span class="product-card__title">Example product</span></div></div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;
    section.querySelectorAll('[data-tab-trigger]').forEach(tab => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tabTrigger;
        section.querySelectorAll('[data-tab-trigger]').forEach(t => { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
        section.querySelectorAll('[data-tab-panel]').forEach(p => { p.classList.remove('is-active'); p.hidden = true; });
        tab.classList.add('is-active');
        tab.setAttribute('aria-selected', 'true');
        const panel = section.querySelector(`[data-tab-panel="${id}"]`);
        if (panel) { panel.classList.add('is-active'); panel.hidden = false; }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Tab collections",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by category" },
    { "type": "range", "id": "products_to_show", "label": "Products per tab", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "select", "id": "columns", "label": "Columns", "default": "4", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" }
    ]}
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        { "type": "text", "id": "title", "label": "Tab title" },
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "presets": [{ "name": "Tab collections", "blocks": [{ "type": "tab" }, { "type": "tab" }, { "type": "tab" }] }]
}
{% endschema %}
