{{ 'section-slideshow.css' | asset_url | stylesheet_tag }}

<section class="banner-image section-padding" data-section-id="{{ section.id }}" style="--banner-height: {{ section.settings.height }};">
  <div class="banner-image__wrapper{% unless section.settings.full_width %} page-width{% endunless %}">
    <div class="banner-image__media{% if section.settings.parallax %} parallax{% endif %}">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1920 | image_tag: loading: 'lazy', sizes: '100vw', widths: '720, 1080, 1440, 1920', class: 'banner-image__img' }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'banner-image__placeholder' }}
      {%- endif -%}
      <div class="banner-image__overlay" style="--overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
    </div>
    <div class="banner-image__content" style="text-align: {{ section.settings.text_position }};">
      {%- if section.settings.subheading != blank -%}
        <p class="banner-image__subheading accent-text animate-on-scroll">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="banner-image__heading heading h1 animate-on-scroll stagger-1">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="banner-image__text animate-on-scroll stagger-2">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link }}" class="btn btn--primary animate-on-scroll stagger-3">{{ section.settings.button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Banner image",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "height", "label": "Height", "default": "60vh", "options": [
      { "value": "auto", "label": "Auto" },
      { "value": "40vh", "label": "Small" },
      { "value": "60vh", "label": "Medium" },
      { "value": "80vh", "label": "Large" },
      { "value": "100vh", "label": "Full screen" }
    ]},
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": true },
    { "type": "checkbox", "id": "parallax", "label": "Parallax effect", "default": false },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Banner heading" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "text_position", "label": "Text position", "default": "center", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ]},
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "default": 20, "unit": "%" }
  ],
  "presets": [{ "name": "Banner image" }]
}
{% endschema %}
